# Lytho Workflow API - OAuth 2.0 client credentials
# Get your Client ID and Client Secret from your Lytho Open API settings page.
# The token URL is tenant-specific — copy it from the same settings page.

LYTHO_CLIENT_ID=wf-oa-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LYTHO_CLIENT_SECRET=your_client_secret_here
LYTHO_TOKEN_URL=https://login.us-1.lytho.us/auth/realms/YOUR_TENANT/protocol/openid-connect/token
